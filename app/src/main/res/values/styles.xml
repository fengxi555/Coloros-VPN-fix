<resources>
    <style name="CloneVpnFixTheme" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowAnimationStyle">@style/CloneVpnFixWindowAnimation</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:colorAccent">#65E7A6</item>
        <item name="android:navigationBarColor">#EDF7F4</item>
        <item name="android:statusBarColor">#FAFDFC</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="CloneVpnFixWindowAnimation">
        <item name="android:activityOpenEnterAnimation">@anim/clone_vpn_fade_in</item>
        <item name="android:activityOpenExitAnimation">@anim/clone_vpn_fade_out</item>
        <item name="android:activityCloseEnterAnimation">@anim/clone_vpn_fade_in</item>
        <item name="android:activityCloseExitAnimation">@anim/clone_vpn_fade_out</item>
        <item name="android:taskOpenEnterAnimation">@anim/clone_vpn_fade_in</item>
        <item name="android:taskOpenExitAnimation">@anim/clone_vpn_fade_out</item>
        <item name="android:taskCloseEnterAnimation">@anim/clone_vpn_fade_in</item>
        <item name="android:taskCloseExitAnimation">@anim/clone_vpn_fade_out</item>
    </style>
</resources>
